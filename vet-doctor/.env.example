# ----------------------------------------------------------------------
# Vet Doctor - Environment variables
# Copy this file to ".env" and adjust the values for your machine.
# ----------------------------------------------------------------------

# Server
PORT=3000
NODE_ENV=development

# Session secret (used from Task 2 onward for express-session)
SESSION_SECRET=change_this_to_a_long_random_string

# Database (SQLite + Sequelize)
# Local development / university demo:
DB_STORAGE=./data/vet_doctor.sqlite
# On Render with a mounted persistent disk, set this instead (see README):
#   DB_STORAGE=/var/data/vet_doctor.sqlite
# Set to "true" to log every SQL query to the console (debugging)
SQL_LOGGING=false

# Seeded administrator account (Task 4). Created on first run if no admin exists.
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@vetdoctor.com
ADMIN_PASSWORD=Admin123!

# Display currency for prices and invoices (Task 6)
CURRENCY=ILS

# Emergency acknowledgement window in minutes (Task 10)
EMERGENCY_ACK_MINUTES=15

# Platform retained margin for report profit calculations (Task 20), 0.2 = 20%
PLATFORM_MARGIN=0.2

# ----------------------------------------------------------------------
# Email (SMTP) for lockout & password-reset emails (SR2.5, SR2.6).
# Leave blank to fall back to console logging (no real email sent).
# Gmail example: enable 2-Step Verification, then create an App Password.
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASS=your-16-char-app-password
#   MAIL_FROM=Vet Doctor <youraddress@gmail.com>
# ----------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
