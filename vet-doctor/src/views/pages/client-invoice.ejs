<%- include('../partials/header') %>

<section class="dashboard">
  <h1>Invoice</h1>

  <div class="card" style="margin-bottom:1.25rem;">
    <h3>Visit details</h3>
    <ul class="detail-list">
      <li><strong>Service date:</strong> <%= new Date(appointment.appointmentDateTime).toLocaleDateString() %></li>
      <li><strong>Veterinarian:</strong> <%= appointment.veterinarian ? 'Dr. ' + appointment.veterinarian.fullName : '-' %></li>
      <li><strong>Service:</strong> <%= appointment.service ? appointment.service.name : '-' %></li>
      <li><strong>Animal:</strong> <%= appointment.animal ? appointment.animal.name : '-' %></li>
    </ul>
  </div>

  <div class="card" style="margin-bottom:1.25rem;">
    <h3>Charges</h3>
    <table class="data-table">
      <thead><tr><th>Description</th><th class="num">Amount (<%= currency %>)</th></tr></thead>
      <tbody>
        <tr>
          <td><%= appointment.service ? appointment.service.name : 'Service' %> (base charge)</td>
          <td class="num"><%= Number(invoice.baseAmount).toFixed(2) %></td>
        </tr>
        <% (invoice.items || []).forEach(function (item) { %>
          <tr>
            <td><%= item.description %></td>
            <td class="num"><%= Number(item.amount).toFixed(2) %></td>
          </tr>
        <% }); %>
      </tbody>
      <tfoot>
        <tr>
          <td><strong>Total</strong></td>
          <td class="num"><strong><%= Number(invoice.totalAmount).toFixed(2) %> <%= currency %></strong></td>
        </tr>
      </tfoot>
    </table>

    <p style="margin-top:0.75rem;">
      <strong>Status:</strong>
      <% if (invoice.status === statuses.PAID) { %>
        <span class="badge badge-success">Paid</span>
      <% } else { %>
        <span class="badge badge-warning">Unpaid</span>
      <% } %>
    </p>
  </div>

  <%
    var hasAdditional = Number(invoice.additionalCharges) > 0;
    var payment = invoice.payment;
    var paid = invoice.status === statuses.PAID;
  %>

  <% if (!paid) { %>
    <% if (hasAdditional && !invoice.additionalChargesAcknowledged) { %>
      <div class="card" style="margin-bottom:1.25rem;">
        <h3>Acknowledge additional charges</h3>
        <p>This invoice includes post-visit charges totalling
          <strong><%= Number(invoice.additionalCharges).toFixed(2) %> <%= currency %></strong>.
          Please acknowledge them before paying.</p>
        <form action="/client/appointments/<%= appointment.id %>/invoice/acknowledge" method="POST">
          <button type="submit" class="btn btn-primary">I acknowledge the charges</button>
        </form>
      </div>
    <% } %>

    <div class="card">
      <h3>Payment</h3>
      <% if (payment && payment.paymentMethod === methods.CASH_ON_DELIVERY
             && payment.paymentStatus === statuses.PENDING) { %>
        <p class="muted">You chose to pay by cash. Awaiting the veterinarian's confirmation of receipt.</p>
      <% } else { %>
        <% var blocked = hasAdditional && !invoice.additionalChargesAcknowledged; %>
        <% if (payment && payment.paymentStatus === statuses.FAILED) { %>
          <p class="alert alert-error">A previous card payment failed. You can try again or pay by cash.</p>
        <% } %>
        <p>Choose how you would like to pay:</p>
        <div class="action-row">
          <% if (enabledMethods.cash) { %>
            <form action="/client/appointments/<%= appointment.id %>/invoice/pay-cash" method="POST">
              <button type="submit" class="btn btn-secondary" <%= blocked ? 'disabled' : '' %>>Pay by Cash</button>
            </form>
          <% } %>
          <% if (enabledMethods.card) { %>
            <% if (blocked) { %>
              <button class="btn btn-primary" disabled>Pay by Card</button>
            <% } else { %>
              <a class="btn btn-primary" href="/client/appointments/<%= appointment.id %>/invoice/pay-card">Pay by Card</a>
            <% } %>
          <% } %>
        </div>
        <% if (!enabledMethods.cash && !enabledMethods.card) { %>
          <p class="muted">No payment methods are currently available. Please check back later.</p>
        <% } %>
      <% } %>
    </div>
  <% } else { %>
    <div class="card">
      <h3>Payment</h3>
      <p>Paid by <strong><%= payment ? paymentMethodLabel(payment.paymentMethod) : '-' %></strong>
        <% if (payment && payment.paymentDate) { %>
          on <%= new Date(payment.paymentDate).toLocaleString() %>
        <% } %>.
      </p>
    </div>
  <% } %>

  <p style="margin-top:1.25rem;">
    <a class="btn btn-secondary" href="/client/appointments/<%= appointment.id %>/invoice/pdf">Download PDF</a>
  </p>

  <p style="margin-top:1rem;"><a href="/client/appointments">&larr; Back to appointments</a></p>
</section>

<%- include('../partials/footer') %>
