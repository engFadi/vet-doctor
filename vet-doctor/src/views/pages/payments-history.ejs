<%- include('../partials/header') %>

<section class="dashboard">
  <h1>Payment history</h1>

  <form action="<%= basePath %>/payments" method="GET" class="filter-bar">
    <label for="from">From</label>
    <input type="date" id="from" name="from" value="<%= from %>" />
    <label for="to">To</label>
    <input type="date" id="to" name="to" value="<%= to %>" />
    <button type="submit" class="btn btn-small btn-primary">Filter</button>
    <% if (from || to) { %>
      <a class="btn btn-small btn-secondary" href="<%= basePath %>/payments">Clear</a>
    <% } %>
  </form>

  <% if (invoices.length === 0) { %>
    <div class="card">
      <p class="muted">No invoices found for the selected period.</p>
    </div>
  <% } else { %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Issue date</th>
          <th>Service</th>
          <th><%= role === 'client' ? 'Veterinarian' : 'Client' %></th>
          <th class="num">Total (<%= currency %>)</th>
          <th>Method</th>
          <th>Status</th>
          <th>Invoice</th>
        </tr>
      </thead>
      <tbody>
        <% invoices.forEach(function (inv) { %>
          <% var appt = inv.appointment; %>
          <tr>
            <td><%= inv.issueDate %></td>
            <td><%= appt && appt.service ? appt.service.name : '-' %></td>
            <td>
              <% if (role === 'client') { %>
                <%= appt && appt.veterinarian ? 'Dr. ' + appt.veterinarian.fullName : '-' %>
              <% } else { %>
                <%= appt && appt.client ? appt.client.fullName : '-' %>
              <% } %>
            </td>
            <td class="num"><%= Number(inv.totalAmount).toFixed(2) %></td>
            <td><%= inv.payment ? paymentMethodLabel(inv.payment.paymentMethod) : '-' %></td>
            <td>
              <% if (inv.status === 'PAID') { %>
                <span class="badge badge-success">Paid</span>
              <% } else { %>
                <span class="badge badge-warning"><%= paymentStatusLabel(inv.status) %></span>
              <% } %>
            </td>
            <td>
              <div class="action-row">
                <a class="btn btn-small btn-secondary"
                   href="<%= basePath %>/appointments/<%= appt.id %>/invoice/pdf">PDF</a>
                <% if (role === 'client') { %>
                  <a class="btn btn-small btn-secondary"
                     href="/client/appointments/<%= appt.id %>/invoice">View</a>
                <% } %>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>

  <p style="margin-top:1.5rem;"><a href="/dashboard">&larr; Back to dashboard</a></p>
</section>

<%- include('../partials/footer') %>
