<%- include('../partials/header') %>

<section class="dashboard">
  <h1>Welcome, Dr. <%= user.fullName %></h1>
  <p class="lead">Veterinarian dashboard</p>

  <div class="card-grid">
    <article class="card">
      <h3>My professional profile</h3>
      <ul class="detail-list">
        <li><strong>Email:</strong> <%= user.email %></li>
        <li><strong>Phone:</strong> <%= user.phoneNumber || '-' %></li>
        <li><strong>License #:</strong> <%= user.licenseNumber || '-' %></li>
        <li><strong>Specialization:</strong> <%= user.specialization || '-' %></li>
        <li><strong>Service area:</strong> <%= user.serviceArea || '-' %></li>
        <li><strong>Experience:</strong>
          <%= user.yearsOfExperience != null ? user.yearsOfExperience + ' years' : '-' %></li>
        <li>
          <strong>Status:</strong>
          <% if (user.isApproved) { %>
            <span class="badge badge-success">Approved</span>
          <% } else { %>
            <span class="badge badge-warning">Pending approval</span>
          <% } %>
        </li>
      </ul>
    </article>

    <article class="card">
      <h3>My availability</h3>
      <p>Add and manage the time slots when you are available for visits.</p>
      <% if (user.isApproved) { %>
        <a class="btn btn-primary" href="/vet/slots">Manage availability</a>
      <% } else { %>
        <p class="muted">Available once your account is approved.</p>
      <% } %>
    </article>

    <article class="card">
      <h3>My appointments</h3>
      <p>View assigned visits and update their status as the visit progresses.</p>
      <% if (user.isApproved) { %>
        <a class="btn btn-primary" href="/vet/appointments">View appointments</a>
      <% } else { %>
        <p class="muted">Available once your account is approved.</p>
      <% } %>
    </article>

    <article class="card">
      <h3>Emergency requests
        <% if (typeof emergencyCount !== 'undefined' && emergencyCount > 0) { %>
          <span class="badge badge-danger"><%= emergencyCount %></span>
        <% } %>
      </h3>
      <p>Acknowledge or decline high-priority emergency visits assigned to you.</p>
      <% if (user.isApproved) { %>
        <a class="btn btn-primary" href="/vet/emergencies">View emergencies</a>
      <% } else { %>
        <p class="muted">Available once your account is approved.</p>
      <% } %>
    </article>

    <article class="card">
      <h3>Payment history</h3>
      <p>Review payments for your visits and download invoices as PDF.</p>
      <% if (user.isApproved) { %>
        <a class="btn btn-secondary" href="/vet/payments">View payments</a>
      <% } else { %>
        <p class="muted">Available once your account is approved.</p>
      <% } %>
    </article>
  </div>
</section>

<%- include('../partials/footer') %>
