<%- include('../partials/header') %>

<section class="dashboard">
  <h1>Medical record</h1>

  <div class="card" style="margin-bottom:1.25rem;">
    <h3>Visit details</h3>
    <ul class="detail-list">
      <li><strong>When:</strong> <%= new Date(appointment.appointmentDateTime).toLocaleString() %></li>
      <li><strong>Service:</strong> <%= appointment.service ? appointment.service.name : '-' %></li>
      <li><strong>Animal:</strong> <%= appointment.animal ? appointment.animal.name + ' (' + appointment.animal.species + ')' : '-' %></li>
      <li><strong>Client:</strong> <%= appointment.client ? appointment.client.fullName : '-' %></li>
      <% if (appointment.followUpDate) { %>
        <li><strong>Follow-up date:</strong> <%= appointment.followUpDate %></li>
      <% } %>
    </ul>
  </div>

  <% if (!record) { %>
    <div class="card">
      <h3>Add medical record</h3>
      <form action="/vet/appointments/<%= appointment.id %>/record" method="POST"
            enctype="multipart/form-data" class="form">
        <label for="diagnosis">Diagnosis</label>
        <textarea id="diagnosis" name="diagnosis" rows="2"></textarea>

        <label for="notes">Post-visit notes <span class="muted">(max <%= maxNotes %> chars)</span></label>
        <textarea id="notes" name="notes" rows="4" maxlength="<%= maxNotes %>"></textarea>

        <label for="attachment">Attachment <span class="muted">(optional, max 10 MB)</span></label>
        <input type="file" id="attachment" name="attachment" />

        <label for="followUpDate">Follow-up date <span class="muted">(optional)</span></label>
        <input type="date" id="followUpDate" name="followUpDate" />

        <button type="submit" class="btn btn-primary">Save record</button>
      </form>
    </div>
  <% } else { %>
    <div class="card" style="margin-bottom:1.25rem;">
      <h3>Record</h3>
      <ul class="detail-list">
        <li><strong>Visit date:</strong> <%= record.visitDate %></li>
        <li><strong>Diagnosis:</strong> <%= record.diagnosis || '-' %></li>
        <li><strong>Notes:</strong> <%= record.notes || '-' %></li>
        <li><strong>Attachment:</strong>
          <% if (record.attachedFile) { %>
            <a href="/uploads/<%= record.attachedFile %>" target="_blank">View file</a>
          <% } else { %> - <% } %>
        </li>
      </ul>
    </div>

    <div class="card">
      <h3>Prescriptions</h3>
      <% if (record.prescriptions && record.prescriptions.length) { %>
        <table class="data-table">
          <thead>
            <tr><th>Medication</th><th>Dosage</th><th>Frequency</th><th>Duration</th><th>Instructions</th></tr>
          </thead>
          <tbody>
            <% record.prescriptions.forEach(function (p) { %>
              <tr>
                <td><%= p.medicationName %></td>
                <td><%= p.dosage || '-' %></td>
                <td><%= p.frequency || '-' %></td>
                <td><%= p.duration || '-' %></td>
                <td><%= p.instructions || '-' %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %>
        <p class="muted">No prescriptions added yet.</p>
      <% } %>

      <h4>Add a prescription</h4>
      <form action="/vet/records/<%= record.id %>/prescriptions" method="POST" class="form">
        <label for="medicationName">Medication name</label>
        <input type="text" id="medicationName" name="medicationName" required />

        <label for="dosage">Dosage</label>
        <input type="text" id="dosage" name="dosage" placeholder="e.g. 50 mg" />

        <label for="frequency">Frequency</label>
        <input type="text" id="frequency" name="frequency" placeholder="e.g. twice daily" />

        <label for="duration">Duration</label>
        <input type="text" id="duration" name="duration" placeholder="e.g. 7 days" />

        <label for="instructions">Instructions</label>
        <textarea id="instructions" name="instructions" rows="2"></textarea>

        <button type="submit" class="btn btn-primary">Add prescription</button>
      </form>
    </div>
  <% } %>

  <% if (invoice) { %>
    <div class="card" style="margin-top:1.25rem;">
      <h3>Invoice &amp; charges</h3>
      <ul class="detail-list">
        <li><strong>Base charge:</strong> <%= Number(invoice.baseAmount).toFixed(2) %> <%= currency %></li>
        <li><strong>Additional charges:</strong> <%= Number(invoice.additionalCharges).toFixed(2) %> <%= currency %></li>
        <li><strong>Total:</strong> <%= Number(invoice.totalAmount).toFixed(2) %> <%= currency %></li>
        <li><strong>Status:</strong> <%= paymentStatusLabel(invoice.status) %></li>
      </ul>

      <% if (invoice.items && invoice.items.length) { %>
        <table class="data-table">
          <thead><tr><th>Description</th><th class="num">Amount</th></tr></thead>
          <tbody>
            <% invoice.items.forEach(function (item) { %>
              <tr><td><%= item.description %></td><td class="num"><%= Number(item.amount).toFixed(2) %></td></tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>

      <% if (invoice.status !== statuses.PAID) { %>
        <h4>Add a post-visit charge</h4>
        <form action="/vet/appointments/<%= appointment.id %>/charges" method="POST" class="form">
          <label for="description">Description</label>
          <input type="text" id="description" name="description" placeholder="e.g. Medication, lab test" required />
          <label for="amount">Amount (<%= currency %>)</label>
          <input type="number" step="0.01" min="0" id="amount" name="amount" required />
          <button type="submit" class="btn btn-primary">Add charge</button>
        </form>

        <% if (invoice.payment && invoice.payment.paymentMethod === methods.CASH_ON_DELIVERY
               && invoice.payment.paymentStatus === statuses.PENDING) { %>
          <hr />
          <p>The client selected <strong>cash</strong> payment of
            <%= Number(invoice.payment.amount).toFixed(2) %> <%= currency %>.</p>
          <form action="/vet/appointments/<%= appointment.id %>/confirm-cash" method="POST">
            <button type="submit" class="btn btn-primary">Confirm cash received</button>
          </form>
        <% } %>
      <% } %>
    </div>
  <% } %>

  <p style="margin-top:1.5rem;"><a href="/vet/appointments">&larr; Back to appointments</a></p>
</section>

<%- include('../partials/footer') %>
