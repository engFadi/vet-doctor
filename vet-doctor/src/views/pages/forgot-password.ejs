<%- include('../partials/header') %>

<section class="auth">
  <h1>Forgot password</h1>

  <% if (sent) { %>
    <div class="alert alert-success">
      If an account exists for that email, a password reset link has been sent.
      The link is valid for 30 minutes.
    </div>
    <% if (!mailConfigured) { %>
      <p class="muted">
        Email sending is not configured on this server, so the reset link was written to the
        server console/logs instead of being emailed.
      </p>
    <% } %>
    <p><a href="/login">Back to log in</a></p>
  <% } else { %>
    <p class="muted">Enter your registered email and we'll send you a reset link.</p>
    <form action="/forgot" method="POST" class="form">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" required autofocus />
      <button type="submit" class="btn btn-primary">Send reset link</button>
    </form>
    <p class="muted" style="margin-top:1rem;"><a href="/login">Back to log in</a></p>
  <% } %>
</section>

<%- include('../partials/footer') %>
