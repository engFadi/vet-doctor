<%- include('../partials/header') %>

<section class="dashboard">
  <h1>Welcome, <%= user.fullName %></h1>
  <p class="lead">Client dashboard</p>

  <div class="card-grid">
    <article class="card">
      <h3>My profile</h3>
      <ul class="detail-list">
        <li><strong>Email:</strong> <%= user.email %></li>
        <li><strong>Phone:</strong> <%= user.phoneNumber || '-' %></li>
        <li><strong>Address:</strong> <%= user.address || '-' %></li>
        <li><strong>Client type:</strong> <%= user.customerType || '-' %></li>
      </ul>
    </article>

    <article class="card">
      <h3>Book a visit</h3>
      <p>Request a home or farm visit for one of your animals.</p>
      <a class="btn btn-primary" href="/client/book">Book a visit</a>
    </article>

    <article class="card">
      <h3>My appointments</h3>
      <p>View and manage your booked visits.</p>
      <a class="btn btn-secondary" href="/client/appointments">View appointments</a>
    </article>

    <article class="card">
      <h3>My animals</h3>
      <p>Add and manage profiles for your pets and livestock.</p>
      <a class="btn btn-secondary" href="/client/animals">Manage my animals</a>
    </article>
  </div>
</section>

<%- include('../partials/footer') %>
