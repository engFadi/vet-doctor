<%- include('../partials/header') %>

<% if (notFound) { %>
  <section class="hero">
    <h1>Page not found</h1>
    <p class="lead">The page you were looking for does not exist. <a href="/">Return home</a>.</p>
  </section>
<% } else { %>
  <section class="hero">
    <h1>Veterinary care that comes to you</h1>
    <p class="lead">
      Vet Doctor connects pet owners and farmers with licensed veterinarians
      who visit your home or farm &mdash; for routine care, emergencies, and livestock.
    </p>
    <div class="hero-actions">
      <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'client') { %>
        <a class="btn btn-primary" href="/client/book">Book a Visit</a>
        <a class="btn btn-secondary" href="/client/appointments">My Appointments</a>
      <% } else { %>
        <a class="btn btn-primary" href="/register/client">Get Started</a>
        <a class="btn btn-secondary" href="/login">Log In</a>
      <% } %>
    </div>
  </section>

  <section class="services">
    <h2>Our Services</h2>
    <div class="card-grid">
      <% services.forEach(function (service) { %>
        <article class="card">
          <h3><%= service.name %></h3>
          <p><%= service.description %></p>
          <p class="price"><strong><%= Number(service.basePrice).toFixed(2) %> <%= currency %></strong>
            <% if (service.estimatedDuration) { %>
              <span class="muted">&middot; ~<%= service.estimatedDuration %> min</span>
            <% } %>
          </p>
        </article>
      <% }); %>
    </div>
  </section>
<% } %>

<%- include('../partials/footer') %>
