<%- include('../partials/header') %>

<section class="dashboard">
  <h1>My appointments</h1>
  <p class="lead">Your assigned visits, sorted by date and time. Update the status as the visit progresses.</p>

  <% if (appointments.length === 0) { %>
    <div class="card">
      <p class="muted">You have no assigned appointments.</p>
    </div>
  <% } else { %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Date &amp; time</th>
          <th>Service</th>
          <th>Animal</th>
          <th>Client</th>
          <th>Location</th>
          <th>Status</th>
          <th>Update</th>
        </tr>
      </thead>
      <tbody>
        <% appointments.forEach(function (appt) { %>
          <tr>
            <td>
              <%= new Date(appt.appointmentDateTime).toLocaleString() %>
              <% if (appt.priorityFlag) { %><span class="badge badge-danger">Emergency</span><% } %>
            </td>
            <td><%= appt.service ? appt.service.name : '-' %></td>
            <td><%= appt.animal ? appt.animal.name + ' (' + appt.animal.species + ')' : '-' %></td>
            <td><%= appt.client ? appt.client.fullName : '-' %>
              <% if (appt.client && appt.client.phoneNumber) { %><br><span class="muted"><%= appt.client.phoneNumber %></span><% } %></td>
            <td><%= appt.visitLocation %></td>
            <td>
              <% if (appt.status === statuses.COMPLETED) { %>
                <span class="badge badge-success"><%= statusLabel(appt.status) %></span>
              <% } else if (appt.status === statuses.CANCELLED) { %>
                <span class="badge badge-danger"><%= statusLabel(appt.status) %></span>
              <% } else { %>
                <span class="badge badge-info"><%= statusLabel(appt.status) %></span>
              <% } %>
            </td>
            <td>
              <% var next = allowedTransitions(appt); %>
              <div class="action-row">
                <% next.forEach(function (s) { %>
                  <form action="/vet/appointments/<%= appt.id %>/status" method="POST">
                    <input type="hidden" name="status" value="<%= s %>" />
                    <button type="submit" class="btn btn-small btn-primary">
                      Mark <%= statusLabel(s) %>
                    </button>
                  </form>
                <% }); %>
                <% if (appt.status === statuses.COMPLETED) { %>
                  <a class="btn btn-small btn-secondary" href="/vet/appointments/<%= appt.id %>/record">Record</a>
                <% } %>
                <% if (appt.status !== statuses.CANCELLED) { %>
                  <a class="btn btn-small btn-secondary" href="/appointments/<%= appt.id %>/messages">Messages</a>
                <% } %>
                <% if (next.length === 0 && appt.status !== statuses.COMPLETED) { %>
                  <span class="muted">-</span>
                <% } %>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>

  <p style="margin-top:1.5rem;"><a href="/dashboard">&larr; Back to dashboard</a></p>
</section>

<%- include('../partials/footer') %>
