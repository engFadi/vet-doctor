<%- include('../partials/header') %>

<section class="dashboard">
  <h1>Administrator dashboard</h1>
  <p class="lead">Welcome, <%= user.fullName %></p>

  <div class="stat-grid">
    <article class="stat-card">
      <span class="stat-number"><%= stats.clientCount %></span>
      <span class="stat-label">Active clients</span>
    </article>
    <article class="stat-card">
      <span class="stat-number"><%= stats.vetCount %></span>
      <span class="stat-label">Registered veterinarians</span>
    </article>
    <a class="stat-card stat-card-link" href="/admin/vets/pending">
      <span class="stat-number"><%= stats.pendingVetCount %></span>
      <span class="stat-label">Veterinarians pending approval</span>
    </a>
    <a class="stat-card stat-card-link" href="/admin/emergencies">
      <span class="stat-number"><%= stats.escalatedCount %></span>
      <span class="stat-label">Escalated emergencies</span>
    </a>
  </div>

  <div class="card-grid">
    <article class="card">
      <h3>Veterinarian approvals</h3>
      <p>Review pending veterinarian registrations, verify their credentials, and approve or reject
         them.</p>
      <a class="btn btn-primary" href="/admin/vets/pending">Review pending veterinarians</a>
    </article>
    <article class="card">
      <h3>Service pricing</h3>
      <p>Update the base price, duration, and description for each service type.</p>
      <a class="btn btn-primary" href="/admin/services">Manage service pricing</a>
    </article>
    <article class="card">
      <h3>Escalated emergencies</h3>
      <p>Review emergencies that could not be auto-assigned and retry assignment.</p>
      <a class="btn btn-primary" href="/admin/emergencies">View escalated emergencies</a>
    </article>

    <article class="card">
      <h3>Review moderation</h3>
      <p>Approve flagged reviews and remove inappropriate ones.</p>
      <a class="btn btn-primary" href="/admin/reviews">Moderate reviews</a>
    </article>

    <article class="card">
      <h3>User management</h3>
      <p>Activate, suspend, deactivate, or delete client and veterinarian accounts.</p>
      <a class="btn btn-primary" href="/admin/users">Manage users</a>
    </article>

    <article class="card">
      <h3>Reports</h3>
      <p>Generate monthly performance reports and export them as PDF or CSV.</p>
      <a class="btn btn-primary" href="/admin/reports">View reports</a>
    </article>
  </div>
</section>

<%- include('../partials/footer') %>
